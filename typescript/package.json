{
  "name": "dataflare-sdk",
  "version": "0.1.4",
  "description": "Official TypeScript SDK for Dataflare API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "dataflare",
    "sdk",
    "grpc",
    "datasets",
    "llm"
  ],
  "author": "Dataflare Lab",
  "license": "MIT",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "axios": "^1.13.6",
    "google-protobuf": "^4.0.2",
    "grpc-js-reflection-client": "^1.3.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "axios-mock-adapter": "^2.1.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
